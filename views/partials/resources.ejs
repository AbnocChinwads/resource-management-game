<h2>Resources</h2>
<ul class="list-group">
    <% resources.forEach(resource=> { %>
        <li class="list-group-item">
            <%= resource.name %>: <%= resource.amount %>
        </li>
        <% }) %>
</ul>
<h2 class="mt-3">Population</h2>
<ul class="list-group">
    <li class="list-group-item">Population: <%= population %>
    </li>
    <li class="list-group-item">Workers: <%= workers %>
    </li>
    <li class="list-group-item">
        Food (total nutrition): <%= food %>
            <% if (food===0) { %>
                <span class="text-danger font-weight-bold"> - Starvation Risk!</span>
                <% } %>
    </li>
</ul>
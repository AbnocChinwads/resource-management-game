<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
  integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
<!--<script>
          setInterval( () => {window.location.reload()},5000);
        </script>-->
<script>
document.addEventListener("DOMContentLoaded", function () {

  let initialLoad = true;

  // Function that updates all progress bars
  function updateProgress() {
    const now = Date.now();
    const bars = document.querySelectorAll(".progress-bar"); // fresh query each time

    bars.forEach(bar => {
      const startedAt = parseInt(bar.dataset.startedAt);
      const craftTime = parseInt(bar.dataset.craftTime) * 1000;

      let progress = (now - startedAt) / craftTime;
      if (progress < 0) progress = 0;
      if (progress > 1) progress = 1;

      const li = bar.closest("li");
      const progressContainer = li.querySelector(".progress");
      const completeContainer = li.querySelector(".complete-container");

      bar.style.width = (progress * 100) + "%";

      if (progress >= 1 && completeContainer) {
        if (initialLoad) {
          if (progressContainer) progressContainer.remove();
          completeContainer.style.display = "block";
        }
      }
    });

    initialLoad = false;
  }

  // Run immediately and every 100ms
  updateProgress();
  setInterval(updateProgress, 100);

  // Transition listener for bars that fill mid-session
  document.addEventListener("transitionend", function(event) {
    if (event.target.classList.contains("progress-bar") && event.propertyName === "width") {
      const bar = event.target;
      const width = parseFloat(bar.style.width);
      if (width >= 100) {
        const li = bar.closest("li");
        const progressContainer = li.querySelector(".progress");
        const completeContainer = li.querySelector(".complete-container");

        if (progressContainer) progressContainer.remove();
        if (completeContainer) completeContainer.style.display = "block";
      }
    }
  });

  // Event delegation for removing completed tasks after form submit
  document.body.addEventListener("submit", function(e) {
    const form = e.target.closest("form");
    if (form && form.closest(".complete-container")) {
      const li = form.closest("li");
      setTimeout(() => li.remove(), 50); // remove after submission
    }
  });

});
</script>
<div class="container fixed-bottom">
  <footer class="d-flex flex-wrap justify-content-between align-items-center py-3 my-4 border-top">
    <p class="col-md-4 mb-0 text-body-secondary">
      Copyright © <%= new Date().getFullYear() %>
    </p>
  </footer>
</div>
</main>
</div>
</body>

</html>
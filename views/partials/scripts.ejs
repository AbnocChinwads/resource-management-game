<!-- ===========================
     1. Game Actions
=========================== -->
<script>
window.changeWorkers = async function (buildingId, delta) {
    console.log("clicked", buildingId, delta);
    try {
        const res = await fetch("/update-workers", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            credentials: "include",
            body: JSON.stringify({ buildingId, delta })
        });

        const data = await res.json();
        if (data.success) {
            document.getElementById(`building-${buildingId}-workers`).textContent = data.workers_assigned;
            const availEl = document.getElementById("available-workers");
            if (availEl) availEl.textContent = data.availableWorkers;
        } else {
            alert(data.error || "Cannot change workers");
        }
    } catch (err) {
        console.error("Worker assignment error:", err);
    }
};

// Complete task handler
document.body.addEventListener("submit", async (e) => {
    const form = e.target;

    if (!form.matches(".complete-form")) return;

    e.preventDefault();

    const formData = new FormData(form);
    const taskId = formData.get("taskId");

    try {
        const res = await fetch("/complete-task", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            credentials: "include",
            body: JSON.stringify({ taskId })
        });

        const data = await res.json();

        if (data.success) {
            // Reload to fetch updated tasks/resources
            window.location.reload();
        } else {
            console.error(data.error);
        }
    } catch (err) {
        console.error("Complete task error:", err);
    }
});
</script>

<!-- ===========================
     2. Live Stats / Progress
=========================== -->
<script>
async function updateStats() {
    try {
        const res = await fetch("/api/player-stats", { credentials: "include" });
        const data = await res.json();

        document.getElementById("population-count").textContent = data.population;
        document.getElementById("worker-count").textContent = data.workers;
        document.getElementById("available-workers").textContent = data.availableWorkers;
        document.getElementById("food-count").textContent = data.food;

        // Update player resources
        data.resources.forEach(r => {
            const el = document.getElementById(`resource-${r.resource_type_id}`);
            if (el) el.textContent = r.amount;
        });

        // Update building workers
        data.buildings.forEach(b => {
            const el = document.getElementById(`building-${b.id}-workers`);
            if (el) el.textContent = b.workers_assigned;
        });
    } catch (err) {
        console.error("Stats update error:", err);
    }
}

// Poll every 3 seconds
setInterval(updateStats, 3000);
updateStats(); // initial call

document.addEventListener("DOMContentLoaded", function () {
    let initialLoad = true;

    function updateProgress() {
        const now = Date.now();
        const bars = document.querySelectorAll(".progress-bar");

        bars.forEach(bar => {
            const startedAt = parseInt(bar.dataset.startedAt);
            const craftTime = parseInt(bar.dataset.craftTime) * 1000;
            if (!startedAt || !craftTime) return;

            let progress = (now - startedAt) / craftTime;
            progress = Math.min(Math.max(progress, 0), 1);

            const li = bar.closest("li");
            if (!li) return;

            const progressContainer = li.querySelector(".progress");
            const completeContainer = li.querySelector(".complete-container");

            bar.style.width = (progress * 100) + "%";

            if (progress >= 1 && completeContainer && initialLoad) {
                if (progressContainer) progressContainer.remove();
                completeContainer.style.display = "block";
            }
        });

        initialLoad = false;
    }

    // Run immediately and every 100ms
    updateProgress();
    setInterval(updateProgress, 100);

    // Transition listener for bars filling mid-session
    document.addEventListener("transitionend", function (event) {
        if (event.target.classList.contains("progress-bar") && event.propertyName === "width") {
            const bar = event.target;
            const width = parseFloat(bar.style.width);
            if (width >= 100) {
                const li = bar.closest("li");
                if (!li) return;

                const progressContainer = li.querySelector(".progress");
                const completeContainer = li.querySelector(".complete-container");

                if (progressContainer) progressContainer.remove();
                if (completeContainer) completeContainer.style.display = "block";
            }
        }
    });
});
</script>

<!-- ===========================
     3. Auth Scripts
=========================== -->
<script>
document.addEventListener("DOMContentLoaded", () => {
    const loginForm = document.getElementById("login-form");
    if (loginForm) {
        loginForm.addEventListener("submit", async (e) => {
            e.preventDefault();
            const username = e.target.username.value;

            try {
                const res = await fetch("/login", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    credentials: "include",
                    body: JSON.stringify({ username }),
                });

                const data = await res.json();
                if (data.success) {
                    window.location.href = "/";
                } else {
                    const errorEl = document.getElementById("error");
                    if (errorEl) errorEl.textContent = data.error || "Login failed";
                }
            } catch (err) {
                console.error("Login error:", err);
            }
        });
    }

    const logoutBtn = document.getElementById("logout-btn");
    if (logoutBtn) {
        logoutBtn.addEventListener("click", async () => {
            try {
                const res = await fetch("/logout", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    credentials: "include",
                });

                const data = await res.json();
                if (data.success) {
                    window.location.href = "/login";
                } else {
                    console.error("Logout failed");
                }
            } catch (err) {
                console.error("Logout error:", err);
            }
        });
    }
});
</script>
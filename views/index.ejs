<%- include('partials/header.ejs'); -%>

    <div class="row">
        <div class="col-3">
            <h2>Resources</h2>
        </div>
        <div class="col-3">
            <ul class="list-group">
                <% resources.forEach(resource=> { %>
                    <li class="list-group-item">
                        <%= resource.resource_type %>: <%= resource.amount %>
                    </li>
                    <% }) %>
            </ul>
        </div>
    </div>
    <div class="row">
        <div class="col-3">
            <h2>Fields</h2>
        </div>
        <div class="col-3">
            <ul class="list-group">
                <% crops.forEach(crop=> { %>
                    <% if (!crop.harvested) { %>
                    <li class="list-group-item">
                            <% if (crop.isReady) { %>
                                <form action="/harvest" method="POST">
                                    <input type="hidden" name="cropId" value="<%= crop.id %>">
                                    <button type="submit" class="btn btn-success">Harvest</button>
                                </form>
                            <% } %>
                        Planted at: <%= crop.planted_at.toLocaleString() %>
                    </li>
                    <% } %>
                    <% }) %>
            </ul>
        </div>
        <div class="col-3">
            <form action="/plant" method="POST">
                <button type="submit" class="btn btn-primary">Plant Wheat</button>
            </form>
        </div>
    </div>
    <%- include('partials/footer.ejs'); -%>
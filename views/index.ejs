<%- include('partials/header.ejs'); -%>

    <div class="row mb-4">
        <div class="col-3">
            <h2>Resources</h2>
            <ul class="list-group">
                <% resources.forEach(resource=> { %>
                    <li class="list-group-item">
                        <%= resource.name %>: <%= resource.amount %>
                    </li>
                    <% }) %>
            </ul>

            <h2 class="mt-3">Population</h2>
            <ul class="list-group">
                <li class="list-group-item">Population: <%= population %>
                </li>
                <li class="list-group-item">Workers: <%= workers %>
                </li>
                <li class="list-group-item">
                    Food (total nutrition): <%= food %>
                        <% if (food===0) { %>
                            <span class="text-danger font-weight-bold"> - Starvation Risk!</span>
                            <% } %>
                </li>
            </ul>
        </div>

        <div class="col-4">
            <h2>Active Tasks</h2>
            <ul class="list-group">
                <% tasks.forEach(task=> { %>
                    <li class="list-group-item">
                        <strong>
                            <%= task.recipe_name %>
                        </strong>
                        <div class="progress" role="progressbar">
                            <div class="progress-bar" data-started-at="<%= task.started_at.getTime() %>"
                                data-craft-time="<%= task.craft_time_seconds %>"></div>
                        </div>

                        <% const inputs=recipeInputs.filter(ri=> ri.recipe_id === task.recipe_id); %>
                            <% if (inputs.length> 0) { %>
                                <small>Needs:
                                    <% inputs.forEach((input, idx)=> {
                                        const resourceName = resources.find(r => r.resource_type_id ===
                                        input.resource_type_id)?.name || '?';
                                        %>
                                        <%= input.amount %>
                                            <%= resourceName %>
                                                <%= idx < inputs.length - 1 ? ', ' : '' %>
                                                    <% }); %>
                                </small>
                                <% } %>

                                    <div class="complete-container mt-2" style="display: none;">
                                        <form action="/complete-task" method="POST">
                                            <input type="hidden" name="taskId" value="<%= task.id %>">
                                            <button type="submit" class="btn btn-success btn-sm">Complete</button>
                                        </form>
                                    </div>
                    </li>
                    <% }) %>
            </ul>
        </div>

        <div class="col-4">
            <h2>Available Recipes</h2>
            <ul class="list-group">
                <% recipes.forEach(recipe=> {
                    const inputs = recipeInputs.filter(ri => ri.recipe_id === recipe.id);
                    let canStart = true;

                    // Check resource requirements
                    inputs.forEach(input => {
                    const playerAmount = resources.find(r => r.resource_type_id === input.resource_type_id)?.amount ||
                    0;
                    if (playerAmount < input.amount) canStart=false; });
                    
                    // Check building requirements
                    if (recipe.required_building_id) { const hasBuilding=buildings.find(b=> b.building_id ===
                        recipe.required_building_id);
                        if (!hasBuilding) canStart = false;
                        }

                        const hideRecipe = recipe.hide_until_available && !canStart;
                        %>
                        <% if (!hideRecipe) { %>
                            <li class="list-group-item <%= canStart ? '' : 'text-muted' %>">
                                <form action="/start-task" method="POST">
                                    <input type="hidden" name="recipeId" value="<%= recipe.id %>">
                                    <button type="submit" class="btn btn-primary btn-sm" <%=canStart ? '' : 'disabled'
                                        %>>
                                        Start <%= recipe.name %>
                                    </button>
                                </form>

                                <% if (!canStart) { %>
                                    <small>
                                        Needs:
                                        <% inputs.forEach((input, idx)=> {
                                            const resourceName = resources.find(r => r.resource_type_id ===
                                            input.resource_type_id)?.name || '?';
                                            %>
                                            <%= input.amount %>
                                                <%= resourceName %>
                                                    <%= idx < inputs.length - 1 ? ', ' : '' %>
                                                        <% }); %>
                                                            <% if (recipe.required_building_id) { %>
                                                                , Requires building: <%= buildings.find(b=>
                                                                    b.building_id === recipe.required_building_id)?.name
                                                                    || '?' %>
                                                                    <% } %>
                                    </small>
                                    <% } %>
                            </li>
                            <% } %>
                                <% }) %>
            </ul>

            <h2 class="mt-4">Your Buildings</h2>
            <ul class="list-group">
                <% buildings.forEach(building=> { %>
                    <li class="list-group-item">
                        <%= building.name %> (Health: <%= building.health %>/<%= building.max_health %>, Workers: <%=
                                        building.workers %>/<%= building.max_workers %>)
                    </li>
                    <% }) %>
            </ul>
        </div>
    </div>

<%- include('partials/footer.ejs'); -%>
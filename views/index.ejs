<%- include('partials/header.ejs'); -%>

    <div class="row">
        <div class="col-3">
            <h2>Resources</h2>
        </div>
        <div class="col-3">
            <ul class="list-group">
                <% resources.forEach(resource=> { %>
                    <li class="list-group-item">
                        <%= resource.name %>: <%= resource.amount %>
                    </li>
                    <% }) %>
            </ul>
        </div>
    </div>

    <div class="row">
        <div class="col-3">
            <h2>Active Tasks</h2>
        </div>

        <div class="col-3">
            <ul class="list-group">
                <% tasks.forEach(task=> { %>
                    <li class="list-group-item">
                        <strong>
                            <%= task.recipe_name %>
                        </strong>
                        <div class="progress" role="progressbar">
                            <div class="progress-bar" data-started-at="<%= task.started_at.getTime() %>"
                                data-craft-time="<%= task.craft_time_seconds %>">
                            </div>
                        </div>
                        <% const inputs=recipeInputs.filter(ri=> ri.recipe_id === task.recipe_id); %>
                            <% if (inputs.length> 0) { %>
                                <small>Needs:
                                    <% inputs.forEach((input, idx)=> {
                                        const resourceName = resources.find(r => r.resource_type_id ===
                                        input.resource_type_id)?.name || '?';
                                        %>
                                        <%= input.amount %>
                                            <%= resourceName %>
                                                <%= idx < inputs.length - 1 ? ', ' : '' %>
                                                    <% }); %>
                                </small>
                                <% } %>
                                    <div class="complete-container mt-2" style="display: none;">
                                        <div class="complete-container">
                                            <form action="/complete-task" method="POST">
                                                <input type="hidden" name="taskId" value="<%= task.id %>">
                                                <button type="submit" class="btn btn-success btn-sm">Complete</button>
                                            </form>
                                        </div>
                                    </div>
                    </li>
                    <% }) %>
            </ul>
        </div>

        <div class="col-3">
            <h2>Available Recipes</h2>

            <ul class="list-group">
                <% recipes.forEach(recipe=> { %>
                    <% const inputs=recipeInputs.filter(ri=> ri.recipe_id ===
                        recipe.id); // Get all inputs for this recipe
                        let canStart = true; // flag to check if all inputs are sufficient
                        %>

                        <% inputs.forEach(input=> { %>
                            <% const playerAmount=resources.find(r=> r.resource_type_id ===
                                input.resource_type_id)?.amount || 0;
                                if (playerAmount < input.amount) canStart=false; %>
                                    <% }); %>

                                        <li class="list-group-item <%= canStart ? '' : 'text-muted' %>">
                                            <form action="/start-task" method="POST">
                                                <input type="hidden" name="recipeId" value="<%= recipe.id %>">
                                                <button type="submit" class="btn btn-primary btn-sm" <%=canStart ? ''
                                                    : 'disabled' %>>
                                                    Start <%= recipe.name %>
                                                </button>
                                            </form>

                                            <% if (!canStart) { %>
                                                <small>
                                                    Needs:
                                                    <% inputs.forEach((input, idx)=> {
                                                        const playerAmount = resources.find(r => r.resource_type_id ===
                                                        input.resource_type_id)?.amount || 0;
                                                        %>
                                                        <%= input.amount %>
                                                            <%= resources.find(r=> r.resource_type_id ===
                                                                input.resource_type_id)?.name || '?' %><%= idx <
                                                                    inputs.length - 1 ? ', ' : '' %>
                                                                    <% }); %>
                                                </small>
                                                <% } %>
                                        </li>
                                        <% }); %>
            </ul>
        </div>

    </div>

    <%- include('partials/footer.ejs'); -%>